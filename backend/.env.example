DATABASE_URL="postgresql://vanzhub:vanzhub@localhost:5432/vanzhub?schema=public"
BACKEND_PORT=4000
BACKEND_URL="http://localhost:4000"
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-this-to-another-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=12
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
REDIS_URL="redis://localhost:6379"
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@vanzhub.com"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_VIDEO_UPLOADS=true
ENABLE_POLLS=true
ENABLE_GIFS=true
ENABLE_SCHEDULED_POSTS=true
ENABLE_DRAFTS=true
ENABLE_GROUPS=true
